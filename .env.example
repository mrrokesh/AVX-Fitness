# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=replace-with-long-random-secret

# Your inbox for new leads (Resend)
ADMIN_NOTIFY_EMAIL=your@email.com

# --- Local PostgreSQL (optional — leave unset to use data/store/db.json) ---
# DATABASE_URL=postgresql://postgres:password@localhost:5432/avx_fitness
# DATABASE_SSL=true

# --- Google Sheets (Apps Script — recommended) ---
GOOGLE_SHEETS_WEBAPP_URL=
GOOGLE_SHEETS_WEBAPP_SECRET=

# --- Google Sheets (service account — alternative) ---
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Google Calendar (optional) ---
GOOGLE_CALENDAR_ID=

# --- Resend email (free ~3000/month) ---
RESEND_API_KEY=
EMAIL_FROM="AVX Fitness <onboarding@resend.dev>"

# Spam protection (optional)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
